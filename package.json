{
  "name": "neobank-digital-payments",
  "version": "1.0.0",
  "description": "NeoBank Digital - Service Paiements & Notifications (sécurisé)",
  "main": "app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --coverage --forceExit",
    "lint": "eslint . --ext .js",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:report": "npm audit --json > npm-audit-report.json",
    "sast": "npx eslint --plugin security . --ext .js"
  },
  "dependencies": {
    "express": "4.21.1",
    "cors": "2.8.5",
    "helmet": "8.0.0",
    "express-rate-limit": "7.4.1",
    "express-slow-down": "2.0.3",
    "express-validator": "7.2.0",
    "dompurify": "3.1.7",
    "jsdom": "25.0.1",
    "he": "1.2.0",
    "dotenv": "16.4.5",
    "winston": "3.15.0",
    "uuid": "10.0.0",
    "jsonwebtoken": "9.0.2",
    "axios": "1.7.7",
    "mongoose": "8.9.5",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "nodemon": "3.1.7",
    "eslint": "9.12.0",
    "eslint-plugin-security": "3.0.1"
  },
  "_comments_security_updates": {
    "express": "4.16.0 → 4.21.1 : CVE-2022-24999 corrigé (prototype pollution via qs)",
    "lodash": "4.17.11 → 4.17.21 : CVE-2020-8203 corrigé (prototype pollution)",
    "axios": "0.18.0 → 1.7.7 : CVE-2019-10742 corrigé (SSRF via URL redirect)",
    "jsonwebtoken": "8.3.0 → 9.0.2 : CVE-2022-23529 corrigé (injection d'objet)",
    "mongoose": "5.7.0 → 8.9.5 : CVE-2022-2564 + GHSA-vg7j-7cwx-8wgw corrigés (injection NoSQL + search injection)",
    "helmet": "3.12.0 → 8.0.0 : Headers de sécurité modernes (HSTS, CSP v3, etc.)"
  }
}

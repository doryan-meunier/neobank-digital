# .env.example - NeoBank Digital
# IMPORTANT : Ce fichier est un MODÈLE sans valeurs sensibles.
#             Copiez-le en .env et remplissez les valeurs réelles.
#             Le fichier .env NE DOIT JAMAIS être commité dans le dépôt Git.
#
# Livrable 3.1 : Gestion sécurisée des secrets (V4)

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# Format : postgresql://user:password@host:port/database
DATABASE_URL=postgresql://neobank_user:CHANGE_ME@localhost:5432/neobank_prod

# ─── JWT (auth_service.py) ────────────────────────────────────────────────────
# Générer une clé forte : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_string_with_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AWS Secrets Manager (optionnel, recommandé en production) ────────────────
# AWS_REGION=eu-west-1
# AWS_SECRET_ARN=arn:aws:secretsmanager:eu-west-1:123456789:secret:neobank/prod

# ─── CORS (app.js) ───────────────────────────────────────────────────────────
# Liste des origines autorisées, séparées par des virgules
CORS_ALLOWED_ORIGINS=https://app.neobank.fr,https://admin.neobank.fr

# ─── Application Node.js ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Application Python/FastAPI ───────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FILE=/var/log/neobank/app.log

# ─── Service externe KYC ──────────────────────────────────────────────────────
# KYC_API_KEY=CHANGE_ME
# KYC_API_URL=https://kyc.provider.com/api/v1

# ─── Service SMS / Push Notifications ────────────────────────────────────────
# TWILIO_ACCOUNT_SID=CHANGE_ME
# TWILIO_AUTH_TOKEN=CHANGE_ME
# FCM_SERVER_KEY=CHANGE_ME

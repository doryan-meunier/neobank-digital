# .gitignore - NeoBank Digital
# Livrable 3.1 : Exclusion des fichiers contenant des secrets (V4)

# ─── SECRETS ET CONFIGURATION SENSIBLE ───────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.development
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
bandit-report.json
pip-audit-report.json

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json   # Facultatif selon la convention du projet
yarn.lock
.npm
npm-audit-report.json
eslint-security-report.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock

# ─── Éditeurs et OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Docker ───────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─── Couverture de tests ──────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Artefacts locaux temporaires ─────────────────────────────────────────────
pytest_artifacts/
pytest_log.txt
*.db
